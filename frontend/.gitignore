# ===================
# Frontend .gitignore (React / Node)
# ===================

# Dependencies
node_modules/

# Build output
dist/
build/

# Environment variables
.env
.env.local
.env.production
.env.development

# IDE
.vscode/
.idea/

# OS files
.DS_Store
Thumbs.db

# Logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Uploaded binary files — never commit these
*.bin
*.exe
*.dll
*.so
*.dylib
*.o
*.obj
*.dat
