# ===================
# Backend .gitignore (Python)
# ===================

# Byte-compiled / optimized
__pycache__/
*.py[cod]
*$py.class

# Virtual environments
.venv/
venv/
env/
ENV/

# Distribution / packaging
build/
dist/
*.egg-info/
*.egg

# Environment variables
.env
.env.*

# IDE
.vscode/
.idea/

# Testing / coverage
.pytest_cache/
htmlcov/
.coverage
coverage.xml

# Uploaded binary files — never commit these
*.bin
*.exe
*.dll
*.so
*.dylib
*.o
*.obj
*.dat
